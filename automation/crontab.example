# More Green Automation — Cron Schedule
# Install: crontab -e  (paste these lines)
# Assumes automation/ is at /home/user/automation

# Post due content Mon/Wed/Fri at 9am
0 9 * * 1,3,5 cd /home/user/automation && python main.py post-organic --platform both >> logs/cron.log 2>&1

# Auto cross-post approved Reels to YouTube Shorts 10 min after the organic run (E8-T2)
10 9 * * 1,3,5 cd /home/user/automation && python main.py post-youtube >> logs/cron.log 2>&1

# Fetch ad insights daily at 6pm
0 18 * * * cd /home/user/automation && python main.py monitor-ads >> logs/cron.log 2>&1

# Apply ad optimisation rules daily at 7pm
0 19 * * * cd /home/user/automation && python main.py tune-ads --apply >> logs/cron.log 2>&1

# ── Autonomous Build Engine ──────────────────────────────────────────────────
# Self-continuing platform build: re-reads build/backlog.yaml each tick and works
# the next ready task. resume.sh no-ops while a run holds the lock, and backs off
# (2->4->8->16m) on usage-limit errors so the build resumes after the limit reset.
# Adjust the repo path to your checkout.
*/15 * * * * cd /path/to/more-green-agi && bash build/resume.sh >> build/logs/cron.log 2>&1
