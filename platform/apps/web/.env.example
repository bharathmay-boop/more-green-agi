# Web tier env. Copy to .env.local (gitignored) and fill real values.
DATABASE_URL="postgresql://moregreen:moregreen@localhost:5432/moregreen?schema=public"
REDIS_URL="redis://localhost:6379"

# Auth (required for login + RBAC). Without SESSION_SECRET, prod authenticates
# nobody and money endpoints refuse. ADMIN_PASSWORD is the interim shared
# operator password checked by /api/auth/login.
SESSION_SECRET="change-me-to-a-long-random-string"
ADMIN_PASSWORD="change-me"

# Non-prod only: elevate the local dev session without logging in.
# DEV_ROLE="owner"
