{% doc %}
  @prompt
    Generate a text field with all format options like font size and bold
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-formatted-text-{{ ai_gen_id }} {
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-formatted-text__content-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    line-height: {{ block.settings.line_height }};
    text-align: {{ block.settings.text_alignment }};
    font-weight: {% if block.settings.bold %}700{% else %}{{ block.settings.font_weight }}{% endif %};
    font-style: {% if block.settings.italic %}italic{% else %}normal{% endif %};
    text-decoration: {% if block.settings.underline %}underline{% else %}none{% endif %};
    letter-spacing: {{ block.settings.letter_spacing }}px;
    text-transform: {{ block.settings.text_transform }};
  }

  .ai-formatted-text__content-{{ ai_gen_id }} strong {
    font-weight: 700;
  }

  .ai-formatted-text__content-{{ ai_gen_id }} em {
    font-style: italic;
  }

  .ai-formatted-text__content-{{ ai_gen_id }} u {
    text-decoration: underline;
  }

  @media screen and (max-width: 749px) {
    .ai-formatted-text__content-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.font_size }}px * 0.9);
    }
  }
{% endstyle %}

<div
  class="ai-formatted-text-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-formatted-text__content-{{ ai_gen_id }}">
    {{ block.settings.text }}
  </div>
</div>

{% schema %}
{
  "name": "Formatted text",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Add your text here. Use the editor to format with bold, italic, and more.</p>"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 12,
      "max": 72,
      "step": 2,
      "unit": "px",
      "label": "Font size",
      "default": 16
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "300",
          "label": "Light"
        },
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "400"
    },
    {
      "type": "checkbox",
      "id": "bold",
      "label": "Bold",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "italic",
      "label": "Italic",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "underline",
      "label": "Underline",
      "default": false
    },
    {
      "type": "select",
      "id": "line_height",
      "label": "Line height",
      "options": [
        {
          "value": "1",
          "label": "Tight"
        },
        {
          "value": "1.2",
          "label": "Snug"
        },
        {
          "value": "1.5",
          "label": "Normal"
        },
        {
          "value": "1.8",
          "label": "Relaxed"
        },
        {
          "value": "2",
          "label": "Loose"
        }
      ],
      "default": "1.5"
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "label": "Letter spacing",
      "default": 0
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Text transform",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        },
        {
          "value": "lowercase",
          "label": "Lowercase"
        },
        {
          "value": "capitalize",
          "label": "Capitalize"
        }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        },
        {
          "value": "justify",
          "label": "Justify"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Formatted text"
    }
  ]
}
{% endschema %}
