{% doc %}
  @prompt
    to showcase contact information
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-info-{{ ai_gen_id }} {
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-contact-info-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-contact-info-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.spacing_between_items }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-contact-info-subheading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.subheading_size }}px;
    margin: 0 0 {{ block.settings.spacing_between_items | times: 1.5 }}px;
    text-align: {{ block.settings.text_alignment }};
    opacity: 0.8;
  }

  .ai-contact-info-items-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.spacing_between_items }}px;
    margin-top: {{ block.settings.spacing_between_items | times: 2 }}px;
  }

  .ai-contact-info-item-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: {{ block.settings.item_padding }}px;
    background-color: {{ block.settings.item_background_color }};
    border-radius: {{ block.settings.item_border_radius }}px;
    text-align: left;
  }

  .ai-contact-info-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.icon_background_color }};
    color: {{ block.settings.icon_color }};
    border-radius: 50%;
  }

  .ai-contact-info-icon-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.icon_size }}px * 0.5);
    height: calc({{ block.settings.icon_size }}px * 0.5);
  }

  .ai-contact-info-content-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
  }

  .ai-contact-info-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    font-weight: 600;
    color: {{ block.settings.heading_color }};
    margin: 0 0 4px;
  }

  .ai-contact-info-value-{{ ai_gen_id }} {
    font-size: {{ block.settings.value_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    word-wrap: break-word;
  }

  .ai-contact-info-value-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: none;
  }

  .ai-contact-info-value-{{ ai_gen_id }} a:hover {
    text-decoration: underline;
  }

  @media screen and (max-width: 749px) {
    .ai-contact-info-items-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-contact-info-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px {{ block.settings.padding_bottom | times: 0.7 }}px;
    }
  }
{% endstyle %}

<div class="ai-contact-info-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-contact-info-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-contact-info-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% if block.settings.subheading != blank %}
      <div class="ai-contact-info-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
    {% endif %}

    <div class="ai-contact-info-items-{{ ai_gen_id }}">
      {% if block.settings.show_phone and block.settings.phone != blank %}
        <div class="ai-contact-info-item-{{ ai_gen_id }}">
          <div class="ai-contact-info-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
          </div>
          <div class="ai-contact-info-content-{{ ai_gen_id }}">
            <div class="ai-contact-info-label-{{ ai_gen_id }}">Phone</div>
            <div class="ai-contact-info-value-{{ ai_gen_id }}">
              <a href="tel:{{ block.settings.phone | replace: ' ', '' }}">{{ block.settings.phone }}</a>
            </div>
          </div>
        </div>
      {% endif %}

      {% if block.settings.show_email and block.settings.email != blank %}
        <div class="ai-contact-info-item-{{ ai_gen_id }}">
          <div class="ai-contact-info-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
          </div>
          <div class="ai-contact-info-content-{{ ai_gen_id }}">
            <div class="ai-contact-info-label-{{ ai_gen_id }}">Email</div>
            <div class="ai-contact-info-value-{{ ai_gen_id }}">
              <a href="mailto:{{ block.settings.email }}">{{ block.settings.email }}</a>
            </div>
          </div>
        </div>
      {% endif %}

      {% if block.settings.show_address and block.settings.address != blank %}
        <div class="ai-contact-info-item-{{ ai_gen_id }}">
          <div class="ai-contact-info-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
          </div>
          <div class="ai-contact-info-content-{{ ai_gen_id }}">
            <div class="ai-contact-info-label-{{ ai_gen_id }}">Address</div>
            <div class="ai-contact-info-value-{{ ai_gen_id }}">{{ block.settings.address }}</div>
          </div>
        </div>
      {% endif %}

      {% if block.settings.show_hours and block.settings.hours != blank %}
        <div class="ai-contact-info-item-{{ ai_gen_id }}">
          <div class="ai-contact-info-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
          </div>
          <div class="ai-contact-info-content-{{ ai_gen_id }}">
            <div class="ai-contact-info-label-{{ ai_gen_id }}">Hours</div>
            <div class="ai-contact-info-value-{{ ai_gen_id }}">{{ block.settings.hours }}</div>
          </div>
        </div>
      {% endif %}

      {% if block.settings.show_whatsapp and block.settings.whatsapp != blank %}
        <div class="ai-contact-info-item-{{ ai_gen_id }}">
          <div class="ai-contact-info-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
          </div>
          <div class="ai-contact-info-content-{{ ai_gen_id }}">
            <div class="ai-contact-info-label-{{ ai_gen_id }}">WhatsApp</div>
            <div class="ai-contact-info-value-{{ ai_gen_id }}">
              <a href="https://wa.me/{{ block.settings.whatsapp | replace: ' ', '' | replace: '+', '' }}" target="_blank" rel="noopener">{{ block.settings.whatsapp }}</a>
            </div>
          </div>
        </div>
      {% endif %}

      {% if block.settings.show_website and block.settings.website != blank %}
        <div class="ai-contact-info-item-{{ ai_gen_id }}">
          <div class="ai-contact-info-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="2" y1="12" x2="22" y2="12"></line>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
            </svg>
          </div>
          <div class="ai-contact-info-content-{{ ai_gen_id }}">
            <div class="ai-contact-info-label-{{ ai_gen_id }}">Website</div>
            <div class="ai-contact-info-value-{{ ai_gen_id }}">
              <a href="{{ block.settings.website }}" target="_blank" rel="noopener">{{ block.settings.website | replace: 'https://', '' | replace: 'http://', '' }}</a>
            </div>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Contact information",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Get in touch"
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "We'd love to hear from you"
    },
    {
      "type": "header",
      "content": "Phone"
    },
    {
      "type": "checkbox",
      "id": "show_phone",
      "label": "Show phone",
      "default": true
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number",
      "default": "+91 98765 43210"
    },
    {
      "type": "header",
      "content": "Email"
    },
    {
      "type": "checkbox",
      "id": "show_email",
      "label": "Show email",
      "default": true
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email address",
      "default": "hello@example.com"
    },
    {
      "type": "header",
      "content": "Address"
    },
    {
      "type": "checkbox",
      "id": "show_address",
      "label": "Show address",
      "default": true
    },
    {
      "type": "textarea",
      "id": "address",
      "label": "Address",
      "default": "123 Main Street, Mumbai, Maharashtra 400001"
    },
    {
      "type": "header",
      "content": "Business hours"
    },
    {
      "type": "checkbox",
      "id": "show_hours",
      "label": "Show hours",
      "default": true
    },
    {
      "type": "textarea",
      "id": "hours",
      "label": "Hours",
      "default": "Mon-Fri: 9:00 AM - 6:00 PM"
    },
    {
      "type": "header",
      "content": "WhatsApp"
    },
    {
      "type": "checkbox",
      "id": "show_whatsapp",
      "label": "Show WhatsApp",
      "default": true
    },
    {
      "type": "text",
      "id": "whatsapp",
      "label": "WhatsApp number",
      "default": "+91 98765 43210"
    },
    {
      "type": "header",
      "content": "Website"
    },
    {
      "type": "checkbox",
      "id": "show_website",
      "label": "Show website",
      "default": false
    },
    {
      "type": "text",
      "id": "website",
      "label": "Website URL",
      "default": "https://example.com"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Columns on desktop",
      "default": 2
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "1"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 600,
      "max": 1400,
      "step": 100,
      "unit": "px",
      "label": "Maximum width",
      "default": 1000
    },
    {
      "type": "range",
      "id": "spacing_between_items",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Spacing between items",
      "default": 20
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link",
      "default": "#08a045"
    },
    {
      "type": "color",
      "id": "item_background_color",
      "label": "Item background",
      "default": "#f5f4f0"
    },
    {
      "type": "color",
      "id": "icon_background_color",
      "label": "Icon background",
      "default": "#08a045"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 32
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Subheading size",
      "default": 16
    },
    {
      "type": "range",
      "id": "label_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Label size",
      "default": 14
    },
    {
      "type": "range",
      "id": "value_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Value size",
      "default": 14
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 0
    },
    {
      "type": "range",
      "id": "item_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Item border radius",
      "default": 8
    },
    {
      "type": "range",
      "id": "item_padding",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Item padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 32,
      "max": 64,
      "step": 4,
      "unit": "px",
      "label": "Icon size",
      "default": 48
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Contact information"
    }
  ]
}
{% endschema %}