{% doc %}
  @prompt
    Create a custom image banner section that:
    1. The entire banner is wrapped in a single anchor tag, making the whole section one big clickable link
    2. No heading, no subheading, no text, no buttons — image only
    3. Has a setting to upload a desktop image and a separate setting to upload a mobile image
    4. Uses a picture element with media queries to swap between desktop and mobile images responsively
    5. Has one URL setting that controls where the entire banner links to
    6. Opens the link in the same tab
    7. Banner is full-width and responsive with no extra padding or margins
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-banner-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    margin: 0;
    padding: 0;
    text-decoration: none;
  }

  .ai-image-banner-{{ ai_gen_id }}:focus-visible {
    outline: 2px solid #000;
    outline-offset: 2px;
  }

  .ai-image-banner-picture-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    margin: 0;
    padding: 0;
    line-height: 0;
  }

  .ai-image-banner-img-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    margin: 0;
    padding: 0;
  }

  .ai-image-banner-placeholder-{{ ai_gen_id }} {
    width: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    min-height: 400px;
  }

  .ai-image-banner-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-image-banner-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }
{% endstyle %}

{% if block.settings.banner_link != blank %}
  <a
    href="{{ block.settings.banner_link }}"
    class="ai-image-banner-{{ ai_gen_id }}"
    {{ block.shopify_attributes }}
  >
{% else %}
  <div
    class="ai-image-banner-{{ ai_gen_id }}"
    {{ block.shopify_attributes }}
  >
{% endif %}

  {% if block.settings.desktop_image or block.settings.mobile_image %}
    <picture class="ai-image-banner-picture-{{ ai_gen_id }}">
      {% if block.settings.mobile_image %}
        <source
          media="(max-width: 749px)"
          srcset="{{ block.settings.mobile_image | image_url: width: 750 }} 750w,
                  {{ block.settings.mobile_image | image_url: width: 1500 }} 1500w"
          width="{{ block.settings.mobile_image.width }}"
          height="{{ block.settings.mobile_image.height }}"
        >
      {% endif %}
      {% if block.settings.desktop_image %}
        <img
          src="{{ block.settings.desktop_image | image_url: width: 1500 }}"
          srcset="{{ block.settings.desktop_image | image_url: width: 1500 }} 1500w,
                  {{ block.settings.desktop_image | image_url: width: 2000 }} 2000w,
                  {{ block.settings.desktop_image | image_url: width: 3000 }} 3000w"
          alt="{{ block.settings.desktop_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.desktop_image.width }}"
          height="{{ block.settings.desktop_image.height }}"
          class="ai-image-banner-img-{{ ai_gen_id }}"
        >
      {% elsif block.settings.mobile_image %}
        <img
          src="{{ block.settings.mobile_image | image_url: width: 1500 }}"
          srcset="{{ block.settings.mobile_image | image_url: width: 750 }} 750w,
                  {{ block.settings.mobile_image | image_url: width: 1500 }} 1500w"
          alt="{{ block.settings.mobile_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.mobile_image.width }}"
          height="{{ block.settings.mobile_image.height }}"
          class="ai-image-banner-img-{{ ai_gen_id }}"
        >
      {% endif %}
    </picture>
  {% else %}
    <div class="ai-image-banner-placeholder-{{ ai_gen_id }}">
      {{ 'hero-apparel-1' | placeholder_svg_tag }}
      <div class="ai-image-banner-empty-state-{{ ai_gen_id }}">
        Next, add desktop and mobile images
      </div>
    </div>
  {% endif %}

{% if block.settings.banner_link != blank %}
  </a>
{% else %}
  </div>
{% endif %}

{% schema %}
{
  "name": "Image banner",
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "header",
      "content": "Link"
    },
    {
      "type": "url",
      "id": "banner_link",
      "label": "Banner link"
    }
  ],
  "presets": [
    {
      "name": "Image banner"
    }
  ],
  "tag": null
}
{% endschema %}
