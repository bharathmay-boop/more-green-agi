    "custom_liquid_aNnTky": {
      "type": "custom-liquid",
      "name": "Videos",
      "settings": {
        "custom_liquid": "<style>\n  /* =================================\n     MAIN SLIDER WRAPPER\n     Horizontal scroll container\n  ================================= */\n  .slider-containerv8 {\n    position: relative;\n    width: 100%;\n    overflow-x: auto;\n    display: flex;\n    align-items: center;\n    scroll-snap-type: x mandatory;\n    max-width: 1200px;\n    margin: 0 auto;\n    padding: 0 10px;\n    -ms-overflow-style: none;\n    scrollbar-width: none;\n  }\n\n  .slider-containerv8::-webkit-scrollbar {\n    display: none;\n  }\n\n  /* =================================\n     INNER TRACK\n     Holds all video cards in one row\n  ================================= */\n  .sliderv8 {\n    display: flex;\n    gap: 10px;\n    width: max-content;\n  }\n\n  /* =================================\n     EACH VIDEO CARD\n     Mobile first sizing\n  ================================= */\n  .slidev8 {\n    flex: 0 0 68%;\n    max-width: 260px;\n    scroll-snap-align: center;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    position: relative;\n  }\n\n  /* =================================\n     DESKTOP CARD WIDTH\n  ================================= */\n  @media screen and (min-width: 769px) {\n    .slidev8 {\n      flex: 0 0 260px;\n      max-width: 260px;\n    }\n  }\n\n  /* =================================\n     OUTER VIDEO FRAME\n     Uses one solid border color only\n  ================================= */\n  .with-borderv8 {\n    padding: 2px;\n    border-radius: 14px;\n    background: #560000;\n    width: 100%;\n  }\n\n  /* =================================\n     VIDEO STYLING\n  ================================= */\n  .tiktok-videov8 {\n    width: 100%;\n    height: auto;\n    aspect-ratio: 9 / 16;\n    border-radius: 12px;\n    display: block;\n    background: #000;\n    object-fit: cover;\n  }\n\n  /* =================================\n     PLAY / PAUSE BUTTONS\n  ================================= */\n  .play-buttonv8,\n  .pause-buttonv8 {\n    position: absolute;\n    width: 42px;\n    height: 42px;\n    border: none;\n    background: rgba(17, 17, 17, 0.72);\n    color: #ffffff;\n    border-radius: 50%;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    font-size: 17px;\n    cursor: pointer;\n    z-index: 10;\n    backdrop-filter: blur(4px);\n    -webkit-backdrop-filter: blur(4px);\n    transition: transform 0.2s ease, opacity 0.3s ease;\n  }\n\n  .play-buttonv8:hover,\n  .pause-buttonv8:hover {\n    transform: scale(1.05);\n  }\n\n  .play-buttonv8 {\n    display: flex;\n  }\n\n  .pause-buttonv8 {\n    display: none;\n    opacity: 1;\n  }\n\n  .pause-buttonv8.hiddenv8 {\n    opacity: 0;\n  }\n\n  /* =================================\n     OPTIONAL SECTION SPACING\n  ================================= */\n  .video-slider-sectionv8 {\n    width: 100%;\n  }\n</style>\n\n<div class=\"video-slider-sectionv8\">\n  <div class=\"slider-containerv8\">\n    <div class=\"sliderv8\">\n\n      <div class=\"slidev8\">\n        <div class=\"with-borderv8\">\n          <video class=\"tiktok-videov8\" playsinline preload=\"metadata\">\n            <source src=\"https://cdn.shopify.com/videos/c/o/v/6d62070d4ee74e019406e641a0611c72.mp4#t=0.001\" type=\"video/mp4\">\n          </video>\n        </div>\n        <button class=\"pause-buttonv8 hiddenv8\" aria-label=\"Pause video\">❚❚</button>\n        <button class=\"play-buttonv8\" aria-label=\"Play video\">▶</button>\n      </div>\n\n      <div class=\"slidev8\">\n        <div class=\"with-borderv8\">\n          <video class=\"tiktok-videov8\" playsinline preload=\"metadata\">\n            <source src=\"https://cdn.shopify.com/videos/c/o/v/cbecbb5a514748fa91dfb97aad6c84a2.mp4#t=0.001\" type=\"video/mp4\">\n          </video>\n        </div>\n        <button class=\"pause-buttonv8 hiddenv8\" aria-label=\"Pause video\">❚❚</button>\n        <button class=\"play-buttonv8\" aria-label=\"Play video\">▶</button>\n      </div>\n\n      <div class=\"slidev8\">\n        <div class=\"with-borderv8\">\n          <video class=\"tiktok-videov8\" playsinline preload=\"metadata\">\n            <source src=\"https://cdn.shopify.com/videos/c/o/v/af68ec106d0b4bd9b8ab61e5019515e7.mp4#t=0.001\" type=\"video/mp4\">\n          </video>\n        </div>\n        <button class=\"pause-buttonv8 hiddenv8\" aria-label=\"Pause video\">❚❚</button>\n        <button class=\"play-buttonv8\" aria-label=\"Play video\">▶</button>\n      </div>\n\n      <div class=\"slidev8\">\n        <div class=\"with-borderv8\">\n          <video class=\"tiktok-videov8\" playsinline preload=\"metadata\">\n            <source src=\"https://cdn.shopify.com/videos/c/o/v/606336a027544b4ca4424d403d79c809.mp4#t=0.001\" type=\"video/mp4\">\n          </video>\n        </div>\n        <button class=\"pause-buttonv8 hiddenv8\" aria-label=\"Pause video\">❚❚</button>\n        <button class=\"play-buttonv8\" aria-label=\"Play video\">▶</button>\n      </div>\n\n      <div class=\"slidev8\">\n        <div class=\"with-borderv8\">\n          <video class=\"tiktok-videov8\" playsinline preload=\"metadata\">\n            <source src=\"https://cdn.shopify.com/videos/c/o/v/de8e751ab44d4537ab0afdf798b80b39.mp4#t=0.001\" type=\"video/mp4\">\n          </video>\n        </div>\n        <button class=\"pause-buttonv8 hiddenv8\" aria-label=\"Pause video\">❚❚</button>\n        <button class=\"play-buttonv8\" aria-label=\"Play video\">▶</button>\n      </div>\n\n    </div>\n  </div>\n</div>\n\n<script>\n  document.addEventListener(\"DOMContentLoaded\", () => {\n    const slides = document.querySelectorAll(\".slidev8\");\n\n    /* --- Force first-frame thumbnail on all browsers (iOS Safari fallback) --- */\n    document.querySelectorAll(\".tiktok-videov8\").forEach(video => {\n      video.currentTime = 0.001;\n    });\n\n    function pauseAllVideos(exceptVideo = null) {\n      document.querySelectorAll(\".tiktok-videov8\").forEach(video => {\n        if (video !== exceptVideo) {\n          video.pause();\n          const slide = video.closest(\".slidev8\");\n          if (slide) {\n            const playButton = slide.querySelector(\".play-buttonv8\");\n            const pauseButton = slide.querySelector(\".pause-buttonv8\");\n            playButton.style.display = \"flex\";\n            pauseButton.style.display = \"none\";\n            pauseButton.classList.add(\"hiddenv8\");\n          }\n        }\n      });\n    }\n\n    slides.forEach(slide => {\n      const playButton = slide.querySelector(\".play-buttonv8\");\n      const pauseButton = slide.querySelector(\".pause-buttonv8\");\n      const video = slide.querySelector(\".tiktok-videov8\");\n      let hidePauseButtonTimeout;\n\n      function showPauseButton() {\n        pauseButton.classList.remove(\"hiddenv8\");\n        clearTimeout(hidePauseButtonTimeout);\n        hidePauseButtonTimeout = setTimeout(() => {\n          if (!video.paused) {\n            pauseButton.classList.add(\"hiddenv8\");\n          }\n        }, 1200);\n      }\n\n      playButton.addEventListener(\"click\", () => {\n        pauseAllVideos(video);\n        video.play();\n      });\n\n      pauseButton.addEventListener(\"click\", () => {\n        video.pause();\n      });\n\n      video.addEventListener(\"play\", () => {\n        pauseAllVideos(video);\n        playButton.style.display = \"none\";\n        pauseButton.style.display = \"flex\";\n        showPauseButton();\n      });\n\n      video.addEventListener(\"pause\", () => {\n        playButton.style.display = \"flex\";\n        pauseButton.style.display = \"none\";\n        pauseButton.classList.add(\"hiddenv8\");\n      });\n\n      video.addEventListener(\"click\", () => {\n        if (video.paused) {\n          pauseAllVideos(video);\n          video.play();\n        } else {\n          showPauseButton();\n        }\n      });\n\n      video.addEventListener(\"mousemove\", showPauseButton);\n      video.addEventListener(\"touchstart\", showPauseButton, { passive: true });\n    });\n\n    /* --- Auto-pause when scrolled out of view --- */\n    const observer = new IntersectionObserver((entries) => {\n      entries.forEach(entry => {\n        const video = entry.target;\n        if (!entry.isIntersecting && !video.paused) {\n          video.pause();\n        }\n      });\n    }, { threshold: 0.35 });\n\n    document.querySelectorAll(\".tiktok-videov8\").forEach(video => {\n      observer.observe(video);\n    });\n  });\n</script>",
        "color_scheme": "background-1",
        "padding_top": 40,
        "padding_bottom": 52
      }
    },
