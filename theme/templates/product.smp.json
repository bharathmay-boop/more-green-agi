      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Survey Stats Circles</title>\n\n  <style>\n    /* =================================\n       MAIN WRAPPER\n       This holds the whole stats section\n    ================================= */\n    .stats-container {\n      display: flex;\n      flex-direction: column;\n      gap: 10px;\n      justify-content: center;\n      align-items: center;\n      max-width: 600px;\n      margin: auto;\n    }\n\n    /* =================================\n       MAIN HEADING\n       Edit this if you want spacing under title\n    ================================= */\n    .stats-container h2 {\n      font-weight: 600;\n      margin-bottom: 10px;\n    }\n\n    /* =================================\n       EACH ROW\n       One circle + one sentence\n    ================================= */\n    .satisfaction-container {\n      width: 100%;\n      display: flex;\n      align-items: center;\n      gap: 15px;\n      flex-wrap: nowrap;\n      justify-content: flex-start;\n      border-bottom: 1px solid #dddddd;\n      padding: 0 0 10px 0;\n    }\n\n    /* =================================\n       FIRST ROW ONLY\n       Adds a top border to the first item\n    ================================= */\n    .satisfaction-container:nth-child(2) {\n      border-top: 1px solid #dddddd;\n      padding-top: 10px;\n    }\n\n    /* =================================\n       CIRCLE CHART\n       This creates the circular progress ring\n       \n       --percentage controls how full the circle is\n       #560000 is your filled color\n       #d9d9d9 is the empty remainder\n    ================================= */\n    .circular-chart {\n      position: relative;\n      width: 80px;\n      height: 80px;\n      min-width: 80px;\n      min-height: 80px;\n      border-radius: 50%;\n      background: conic-gradient(\n        #08A045 0% var(--percentage),\n        #d9d9d9 var(--percentage) 100%\n      );\n      flex-shrink: 0;\n    }\n\n    /* =================================\n       WHITE CENTER CIRCLE\n       This creates the donut effect\n    ================================= */\n    .circular-chart::after {\n      content: \"\";\n      position: absolute;\n      top: 11%;\n      left: 11%;\n      width: 78%;\n      height: 78%;\n      background: white;\n      border-radius: 50%;\n    }\n\n    /* =================================\n       PERCENTAGE TEXT INSIDE CIRCLE\n       Example: 90%\n    ================================= */\n    .percentage {\n      position: absolute;\n      top: 50%;\n      left: 50%;\n      transform: translate(-50%, -50%);\n      font-size: 18px;\n      font-weight: bold;\n      z-index: 1;\n      color: #111111;\n    }\n\n    /* =================================\n       TEXT TO THE RIGHT OF EACH CIRCLE\n    ================================= */\n    .satisfaction-text {\n      font-size: 15px;\n      font-weight: 500;\n      flex-grow: 1;\n      white-space: normal;\n      color: #111111;\n      line-height: 1.4;\n    }\n\n    /* =================================\n       MOBILE STYLES\n       Makes the circles slightly smaller on phones\n    ================================= */\n    @media (max-width: 600px) {\n      .satisfaction-container {\n        gap: 12px;\n        padding: 0 10px 10px 10px;\n      }\n\n      .satisfaction-container:nth-child(2) {\n        padding-top: 10px;\n      }\n\n      .circular-chart {\n        width: 65px;\n        height: 65px;\n        min-width: 65px;\n        min-height: 65px;\n      }\n\n      .percentage {\n        font-size: 16px;\n      }\n\n      .satisfaction-text {\n        font-size: 14px;\n      }\n    }\n  </style>\n</head>\n\n<body>\n  <div class=\"stats-container\">\n\n    <!-- ================================\n         MAIN HEADING\n         Change this text to your heading\n    ================================= -->\n    <h2>Why Customers Love It</h2>\n\n    <!-- ================================\n         STAT ROW 1\n         data-target=\"90\" means it fills to 90%\n    ================================= -->\n    <div class=\"satisfaction-container\">\n      <div class=\"circular-chart\" data-target=\"92\" style=\"--percentage: 0%;\">\n        <div class=\"percentage\">0%</div>\n      </div>\n      <div class=\"satisfaction-text\">\n        of customers said they felt more energetic and sustained through the afternoon after 2+ weeks of consistent daily use\n      </div>\n    </div>\n\n    <!-- ================================\n         STAT ROW 2\n    ================================= -->\n    <div class=\"satisfaction-container\">\n      <div class=\"circular-chart\" data-target=\"87\" style=\"--percentage: 0%;\">\n        <div class=\"percentage\">0%</div>\n      </div>\n      <div class=\"satisfaction-text\">\n        reported reduced reliance on afternoon caffeine within 3 weeks of consistent daily use\n      </div>\n    </div>\n\n    <!-- ================================\n         STAT ROW 3\n    ================================= -->\n    <div class=\"satisfaction-container\">\n      <div class=\"circular-chart\" data-target=\"94\" style=\"--percentage: 0%;\">\n        <div class=\"percentage\">0%</div>\n      </div>\n      <div class=\"satisfaction-text\">\n        would recommend More Green Sunflower Microgreen Powder to a friend or family member looking to add daily plant nutrition without changing how they cook\n      </div>\n    </div>\n\n  </div>\n\n  <script>\n    /* =================================\n       ANIMATE ONE CIRCLE\n       This counts from 0% up to the target number\n    ================================= */\n    function animatePercentage(chart) {\n      let percentageText = chart.querySelector('.percentage');\n      let targetValue = parseInt(chart.getAttribute('data-target'));\n      let currentPercentage = 0;\n\n      function updateChart() {\n        if (currentPercentage <= targetValue) {\n          chart.style.setProperty('--percentage', currentPercentage + '%');\n          percentageText.innerText = currentPercentage + '%';\n          currentPercentage++;\n          requestAnimationFrame(updateChart);\n        }\n      }\n\n      updateChart();\n    }\n\n    /* =================================\n       START ANIMATION WHEN USER SCROLLS\n       This makes the circles animate only\n       when they come into view\n    ================================= */\n    function handleScroll() {\n      const charts = document.querySelectorAll('.circular-chart');\n      const windowHeight = window.innerHeight;\n\n      charts.forEach((chart) => {\n        const chartPosition = chart.getBoundingClientRect().top;\n\n        if (chartPosition < windowHeight - 100 && !chart.classList.contains('animated')) {\n          animatePercentage(chart);\n          chart.classList.add('animated');\n        }\n      });\n    }\n\n    /* =================================\n       RUN ON PAGE LOAD + SCROLL\n    ================================= */\n    window.addEventListener('scroll', handleScroll);\n    document.addEventListener('DOMContentLoaded', handleScroll);\n  </script>\n</body>\n</html>",
        "color_scheme": "",
        "padding_top": 16,
        "padding_bottom": 52
      }
    },
